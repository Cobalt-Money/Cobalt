{
  "name": "@cobalt-web/zero",
  "type": "module",
  "exports": {
    ".": {
      "default": "./src/index.ts"
    },
    "./schema": {
      "default": "./src/schema.ts"
    },
    "./queries": {
      "default": "./src/queries.ts"
    },
    "./mutators": {
      "default": "./src/mutators.ts"
    }
  },
  "scripts": {
    "generate:zero": "drizzle-zero generate --schema ../db/src/schema/drizzle-schema.ts --output ./src/zero-schema.gen.ts --format"
  },
  "dependencies": {
    "@rocicorp/zero": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@cobalt-web/config": "workspace:*",
    "@cobalt-web/db": "workspace:*",
    "drizzle-zero": "^0.17.4",
    "typescript": "^5"
  }
}
