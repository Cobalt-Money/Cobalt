{
  "name": "@cobalt-web/db",
  "license": "AGPL-3.0-only",
  "type": "module",
  "exports": {
    ".": {
      "default": "./src/index.ts"
    },
    "./schema/auth": {
      "default": "./src/schema/auth/auth.ts"
    },
    "./*": {
      "default": "./src/*.ts"
    },
    "./schema/features": {
      "default": "./src/schema/features/index.ts"
    },
    "./schema/news": {
      "default": "./src/schema/news/index.ts"
    }
  },
  "scripts": {
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "db:migrate": "bun run ./scripts/migrate-debug.ts --prod",
    "db:migrate:local": "bun run ./scripts/migrate-debug.ts --local",
    "check:unification-parity": "bun run ./scripts/check-unification-parity.ts"
  },
  "dependencies": {
    "@cobalt-web/env": "workspace:*",
    "dotenv": "catalog:",
    "drizzle-orm": "1.0.0-beta.22",
    "pg": "^8.17.1",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@cobalt-web/config": "workspace:*",
    "@types/pg": "^8.16.0",
    "drizzle-kit": "1.0.0-beta.18-7eb39f0",
    "typescript": "^5"
  }
}
