{
  "name": "@cobalt-web/db",
  "type": "module",
  "exports": {
    ".": {
      "default": "./src/index.ts"
    },
    "./schema/auth": {
      "default": "./src/schema/auth/auth.ts"
    },
    "./*": {
      "default": "./src/*.ts"
    },
    "./schema/banking": {
      "default": "./src/schema/banking/index.ts"
    },
    "./schema/brokerage": {
      "default": "./src/schema/brokerage/index.ts"
    }
  },
  "scripts": {
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@cobalt-web/env": "workspace:*",
    "dotenv": "catalog:",
    "drizzle-orm": "1.0.0-beta.18-7eb39f0",
    "pg": "^8.17.1",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@cobalt-web/config": "workspace:*",
    "@types/pg": "^8.16.0",
    "drizzle-kit": "1.0.0-beta.18-7eb39f0",
    "typescript": "^5"
  }
}
