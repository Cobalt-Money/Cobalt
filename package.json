{
  "name": "cobalt-web",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.4.2",
      "zod": "^4.1.13",
      "@types/bun": "^1.3.13",
      "better-auth": "1.6.8",
      "next-themes": "^0.4.6",
      "react": "^19.2.3",
      "react-dom": "^19.2.3",
      "sonner": "^2.0.5",
      "tailwindcss": "^4.2.4",
      "@types/react": "^19.2.10",
      "@types/react-dom": "^19.2.3",
      "@rocicorp/zero": "^1.3.0"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "start": "turbo run start --filter=web --filter=server --filter=zero-cache --filter=fumadocs",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "dev:app": "turbo dev --filter=server --filter=web",
    "db:push": "drizzle-kit push --config packages/db/drizzle.config.ts",
    "db:studio": "drizzle-kit studio --config packages/db/drizzle.config.ts",
    "db:generate": "drizzle-kit generate --config packages/db/drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config packages/db/drizzle.config.ts",
    "db:migrate:debug": "bun run --cwd packages/db migrate:debug",
    "db:migrate:local": "LOCAL_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5433/cobalt drizzle-kit migrate --config packages/db/drizzle.config.ts",
    "db:local:up": "docker compose -f docker-compose.local-db.yml up -d",
    "db:local:down": "docker compose -f docker-compose.local-db.yml down",
    "db:local:reset": "docker compose -f docker-compose.local-db.yml down -v && docker compose -f docker-compose.local-db.yml up -d",
    "db:local:init": "cat packages/db/planetscale/local-bootstrap.sql | docker compose -f docker-compose.local-db.yml exec -T postgres psql -U postgres -d cobalt",
    "dev:zero": "zero-cache-dev",
    "zero:up": "bun run --cwd apps/zero-cache compose:up",
    "zero:down": "bun run --cwd apps/zero-cache compose:down",
    "zero:logs": "bun run --cwd apps/zero-cache compose:logs",
    "zero:keepalive": "bun run --cwd apps/zero-cache verify:keepalive",
    "zero:generate": "bun run --cwd packages/zero generate:zero",
    "check": "ultracite check && turbo check-types",
    "precommit": "bun check && bun run test",
    "test": "turbo test",
    "fix": "ultracite fix",
    "dump": "bun run scripts/dump.ts",
    "db:check-slots": "bun run scripts/check-slots.ts",
    "db:drop-slots": "bun run scripts/check-slots.ts --drop",
    "sync-env": "bash sync-env.sh",
    "sync-sandbox": "bash sync-sandbox.sh",
    "prepare": "husky"
  },
  "dependencies": {
    "@ai-sdk/gateway": "^3.0.104",
    "@cobalt-web/env": "workspace:*",
    "@tanstack/react-virtual": "^3.13.23",
    "@tiptap/core": "^3",
    "@tiptap/extension-table": "^3.22.4",
    "ai": "^6.0.168",
    "dotenv": "catalog:",
    "plaid": "^41.4.0",
    "workflow": "^4.2.2",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@cobalt-web/config": "workspace:*",
    "@types/bun": "catalog:",
    "drizzle-kit": "1.0.0-beta.18-7eb39f0",
    "husky": "^9.1.7",
    "oxfmt": "latest",
    "oxlint": "latest",
    "oxlint-plugin-eslint": "1.59.0",
    "tailwindcss": "catalog:",
    "turbo": "^2.8.20",
    "typescript": "^6.0.3",
    "ultracite": "7.6.0",
    "vitest": "^3.2.0"
  },
  "packageManager": "bun@1.3.5",
  "trustedDependencies": [
    "@rocicorp/zero-sqlite3"
  ]
}
