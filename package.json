{
  "name": "cobalt-web",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "@types/bun": "^1.3.4",
      "better-auth": "1.5.2",
      "lucide-react": "^0.546.0",
      "next-themes": "^0.4.6",
      "react": "^19.2.3",
      "react-dom": "^19.2.3",
      "sonner": "^2.0.5",
      "tailwindcss": "^4.1.18",
      "@types/react": "^19.2.10",
      "@types/react-dom": "^19.2.3",
      "@rocicorp/zero": "^0.26.1"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "db:push": "turbo -F @cobalt-web/db db:push",
    "db:studio": "turbo -F @cobalt-web/db db:studio",
    "db:generate": "turbo -F @cobalt-web/db db:generate",
    "db:migrate": "turbo -F @cobalt-web/db db:migrate",
    "dev:zero": "zero-cache-dev",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "sync-env": "bash sync-env.sh"
  },
  "dependencies": {
    "@cobalt-web/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@cobalt-web/config": "workspace:*",
    "@types/bun": "catalog:",
    "drizzle-kit": "^0.31.10",
    "oxfmt": "latest",
    "oxlint": "latest",
    "turbo": "^2.8.20",
    "typescript": "^5",
    "ultracite": "7.3.1"
  },
  "packageManager": "bun@1.3.5",
  "trustedDependencies": [
    "@rocicorp/zero-sqlite3"
  ]
}
