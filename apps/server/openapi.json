{
  "info": {
    "description": "The Cobalt public API provides programmatic access to market data, portfolio analytics, and financial insights.",
    "title": "Cobalt Public API",
    "version": "1.0.0"
  },
  "openapi": "3.1.0",
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "components": {
    "schemas": {},
    "parameters": {},
    "securitySchemes": {
      "bearerAuth": {
        "bearerFormat": "OAuth 2.0 Access Token",
        "description": "OAuth 2.0 access token obtained via the authorization code flow",
        "scheme": "bearer",
        "type": "http"
      }
    }
  },
  "paths": {
    "/v1/tickers/{symbol}/quote": {
      "get": {
        "description": "Get the latest quote for a ticker symbol",
        "summary": "Get ticker quote",
        "tags": ["Tickers"],
        "parameters": [
          {
            "schema": {
              "type": "string",
              "minLength": 1,
              "maxLength": 10,
              "description": "Ticker symbol (e.g. AAPL)",
              "example": "AAPL"
            },
            "required": true,
            "description": "Ticker symbol (e.g. AAPL)",
            "name": "symbol",
            "in": "path"
          }
        ],
        "responses": {
          "200": {
            "description": "Ticker quote",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "change": {
                      "type": "number",
                      "example": 1.25
                    },
                    "changePercent": {
                      "type": "number",
                      "example": 0.67
                    },
                    "currency": {
                      "type": "string",
                      "example": "USD"
                    },
                    "high": {
                      "type": "number",
                      "example": 189.98
                    },
                    "low": {
                      "type": "number",
                      "example": 186.01
                    },
                    "marketCap": {
                      "type": "number",
                      "example": 2940000000000
                    },
                    "open": {
                      "type": "number",
                      "example": 187.15
                    },
                    "price": {
                      "type": "number",
                      "example": 188.4
                    },
                    "symbol": {
                      "type": "string",
                      "example": "AAPL"
                    },
                    "volume": {
                      "type": "number",
                      "example": 58234100
                    }
                  },
                  "required": [
                    "change",
                    "changePercent",
                    "currency",
                    "high",
                    "low",
                    "open",
                    "price",
                    "symbol",
                    "volume"
                  ]
                }
              }
            }
          },
          "404": {
            "description": "Ticker not found",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "object",
                      "properties": {
                        "code": {
                          "type": "string",
                          "example": "NOT_FOUND"
                        },
                        "details": {
                          "type": "object",
                          "additionalProperties": {}
                        },
                        "message": {
                          "type": "string",
                          "example": "Ticker not found"
                        }
                      },
                      "required": ["code", "message"]
                    }
                  },
                  "required": ["error"]
                }
              }
            }
          },
          "422": {
            "description": "Validation failed",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "object",
                      "properties": {
                        "issues": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "code": {
                                "type": "string"
                              },
                              "message": {
                                "type": "string"
                              },
                              "path": {
                                "type": "array",
                                "items": {
                                  "anyOf": [
                                    {
                                      "type": "string"
                                    },
                                    {
                                      "type": "number"
                                    }
                                  ]
                                }
                              }
                            },
                            "required": ["code", "message", "path"]
                          }
                        },
                        "name": {
                          "type": "string"
                        }
                      },
                      "required": ["issues", "name"]
                    },
                    "success": {
                      "type": "boolean",
                      "enum": [false]
                    }
                  },
                  "required": ["error", "success"]
                }
              }
            }
          }
        }
      }
    },
    "/v1/tickers/search": {
      "get": {
        "description": "Search for tickers by name or symbol",
        "summary": "Search tickers",
        "tags": ["Tickers"],
        "parameters": [
          {
            "schema": {
              "type": "number",
              "minimum": 1,
              "maximum": 50,
              "default": 10,
              "description": "Max results to return",
              "example": 10
            },
            "required": false,
            "description": "Max results to return",
            "name": "limit",
            "in": "query"
          },
          {
            "schema": {
              "type": "string",
              "minLength": 1,
              "description": "Search query",
              "example": "apple"
            },
            "required": true,
            "description": "Search query",
            "name": "q",
            "in": "query"
          }
        ],
        "responses": {
          "200": {
            "description": "Search results",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "results": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "exchange": {
                            "type": "string",
                            "example": "NASDAQ"
                          },
                          "name": {
                            "type": "string",
                            "example": "Apple Inc."
                          },
                          "symbol": {
                            "type": "string",
                            "example": "AAPL"
                          },
                          "type": {
                            "type": "string",
                            "example": "equity"
                          }
                        },
                        "required": ["exchange", "name", "symbol", "type"]
                      }
                    }
                  },
                  "required": ["results"]
                }
              }
            }
          },
          "422": {
            "description": "Validation failed",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "object",
                      "properties": {
                        "issues": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "code": {
                                "type": "string"
                              },
                              "message": {
                                "type": "string"
                              },
                              "path": {
                                "type": "array",
                                "items": {
                                  "anyOf": [
                                    {
                                      "type": "string"
                                    },
                                    {
                                      "type": "number"
                                    }
                                  ]
                                }
                              }
                            },
                            "required": ["code", "message", "path"]
                          }
                        },
                        "name": {
                          "type": "string"
                        }
                      },
                      "required": ["issues", "name"]
                    },
                    "success": {
                      "type": "boolean",
                      "enum": [false]
                    }
                  },
                  "required": ["error", "success"]
                }
              }
            }
          }
        }
      }
    }
  },
  "webhooks": {},
  "servers": [
    {
      "description": "Production",
      "url": "https://api.cobaltpf.com"
    }
  ]
}
