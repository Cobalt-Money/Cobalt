# Server env — validated in packages/env/src/server.ts
# Copy to `.env` in this folder for local dev.
#
# NOTE: Cobalt is open-source for transparency; self-hosting is unsupported.
# Many required vars below correspond to managed services we run in production
# (Plaid, SnapTrade, Apple, etc.). For local exploration you can stub the
# values with any non-empty string — endpoints that hit those providers will
# fail at request time but the server will boot.

# --- Required: core ---

# Postgres connection string for the app (Drizzle + Better Auth).
DATABASE_URL=postgres://postgres:postgres@localhost:5432/cobalt

# Better Auth secret (min 32 chars). Generate: `openssl rand -base64 48`
BETTER_AUTH_SECRET=replace-me-with-32-plus-random-chars-please

# Public origin Better Auth treats as canonical for this server.
BETTER_AUTH_URL=http://localhost:3000

# Allowed CORS origin (the web app).
CORS_ORIGIN=http://localhost:5173

# Vercel Blob token (CSV imports). Stub OK for local.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_local

# --- Required: OAuth providers ---

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_IOS_CLIENT_ID=

APPLE_APP_BUNDLE_IDENTIFIER=com.example.cobalt
APPLE_SERVICE_ID=com.example.cobalt.service
APPLE_TEAM_ID=ABCDE12345
APPLE_KEY_ID=ABCDE12345
APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# --- Required: data providers ---

PLAID_CLIENT_ID=
PLAID_CLIENT_SECRET=
PLAID_ENV=sandbox

SNAPTRADE_CLIENT_ID=
SNAPTRADE_CONSUMER_KEY=

STOCK_NEWS_API_KEY=

# --- Required: billing ---

STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Optional ---

# Vercel AI Gateway. Chat/agent endpoints return 503 without it.
# AI_GATEWAY_API_KEY=
# AI_GATEWAY_MODEL=anthropic/claude-haiku-4.5

# Public web app URL (Stripe return URLs).
# APP_URL=http://localhost:5173

# Cross-subdomain auth cookies (prod only, e.g. ".cobaltpf.com").
# COOKIE_DOMAIN=

# Vercel Cron auth token.
# CRON_SECRET=

# Financial Modeling Prep — market data.
# FMP_API_KEY=

# Parallel web search (agent tools).
# PARALLEL_API_KEY=

# Plaid webhook URL (must be publicly reachable; use ngrok in dev).
# PLAID_WEBHOOK_URL=https://your-tunnel/api/webhooks/plaid

# Apple App Store webhooks (production builds).
# APPLE_APP_ID=
# APPLE_APP_STORE_ENVIRONMENT=Sandbox

# Sandbox CF Worker for agent code execution.
# SANDBOX_WORKER_URL=
# SANDBOX_WORKER_AUTH_TOKEN=

# Upstash Redis (rate limits). Falls back to in-memory when unset.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Comma-separated extra trusted origins for Better Auth.
# TRUSTED_ORIGINS_EXTRA=

# DB pool tuning.
# DATABASE_POOL_MAX=5
# ZERO_DB_POOL_MAX=2

# Local DB superuser URL for migrations.
# LOCAL_DATABASE_URL=
# MIGRATION_URI=

# NODE_ENV=development
