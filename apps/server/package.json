{
  "name": "server",
  "license": "AGPL-3.0-only",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "nitro build",
    "check-types": "tsc --noEmit",
    "dev": "nitro dev",
    "start": "node .output/server/index.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts --exclude '**/*.happy.integration.test.ts'",
    "test:integration:happy": "vitest run --config vitest.integration.config.ts tests/workflows/news/financial-events.happy.integration.test.ts",
    "test:integration:all": "vitest run --config vitest.integration.config.ts",
    "eval": "evalite watch \"src/ai/agents/**/*.eval.ts\"",
    "eval:run": "evalite \"src/ai/agents/**/*.eval.ts\"",
    "eval:ci": "RUN_EVALS=1 evalite \"src/ai/agents/**/*.eval.ts\" --threshold=70",
    "generate-spec": "bun scripts/generate-spec.ts",
    "verify-spec": "bun scripts/generate-spec.ts && git diff --exit-code openapi.json || (echo 'openapi.json drift — run `bun --filter server generate-spec` and commit' && exit 1)"
  },
  "dependencies": {
    "@ai-sdk/gateway": "^3.0.84",
    "@better-auth/oauth-provider": "1.7.0-beta.3",
    "@cobalt-web/auth": "workspace:*",
    "@cobalt-web/bindings": "workspace:*",
    "@cobalt-web/clients": "workspace:*",
    "@cobalt-web/db": "workspace:*",
    "@cobalt-web/env": "workspace:*",
    "@cobalt-web/server-data": "workspace:*",
    "@cobalt-web/zero": "workspace:*",
    "@hono/zod-openapi": "^1.2.2",
    "@json-render/core": "^0.19.0",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@parallel-web/ai-sdk-tools": "^0.2.1",
    "@rocicorp/zero": "catalog:",
    "@scalar/hono-api-reference": "^0.10.4",
    "@tanstack/ai": "^0.22.1",
    "@tanstack/ai-code-mode": "^0.1.9",
    "@tanstack/ai-isolate-cloudflare": "^0.2.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "@vercel/queue": "^0.2.0",
    "ai": "^6",
    "bash-tool": "^1.3.14",
    "better-auth": "catalog:",
    "dotenv": "catalog:",
    "drizzle-orm": "1.0.0-beta.22",
    "hono": "^4.8.2",
    "jose": "^6.1.0",
    "mathjs": "^15.1.0",
    "p-limit": "^6.2.0",
    "pg": "^8.16.3",
    "snaptrade-typescript-sdk": "^9.0.160",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@cobalt-web/config": "workspace:*",
    "@types/bun": "catalog:",
    "@types/pg": "^8.16.0",
    "@types/uuid": "^11.0.0",
    "autoevals": "^0.0.132",
    "evalite": "^0.19.0",
    "nitro": "^3.0.260522-beta",
    "rollup": "^4.60.1",
    "typescript": "^5",
    "vitest": "^3.2.0",
    "workflow": "^4.2.2"
  }
}
