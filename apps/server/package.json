{
  "name": "server",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "bun ./scripts/gen-schema-files.ts && nitro build",
    "check-types": "bun ./scripts/gen-schema-files.ts && tsc -b",
    "dev": "bun ./scripts/gen-schema-files.ts && nitro dev",
    "gen:schema-files": "bun ./scripts/gen-schema-files.ts",
    "start": "node .output/server/index.mjs",
    "extract-openapi": "bun ./scripts/extract-openapi.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@ai-sdk/gateway": "^3.0.84",
    "@better-auth/oauth-provider": "1.5.6",
    "@cobalt-web/auth": "workspace:*",
    "@cobalt-web/clients": "workspace:*",
    "@cobalt-web/db": "workspace:*",
    "@cobalt-web/env": "workspace:*",
    "@cobalt-web/server-data": "workspace:*",
    "@cobalt-web/zero": "workspace:*",
    "@hono/zod-openapi": "^1.2.2",
    "@json-render/core": "^0.4.4",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@rocicorp/zero": "catalog:",
    "@scalar/hono-api-reference": "^0.10.4",
    "ai": "^6",
    "bash-tool": "^1.3.14",
    "better-auth": "catalog:",
    "dotenv": "catalog:",
    "drizzle-orm": "1.0.0-beta.18-7eb39f0",
    "hono": "^4.8.2",
    "mathjs": "^15.1.0",
    "parallel-web": "^0.3.1",
    "pg": "^8.16.3",
    "snaptrade-typescript-sdk": "^9.0.160",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@cobalt-web/config": "workspace:*",
    "@types/bun": "catalog:",
    "@types/pg": "^8.16.0",
    "nitro": "^3.0.260415-beta",
    "rollup": "^4.60.1",
