{
  "name": "server",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "dev": "bun run --hot src/index.ts",
    "start": "bun run dist/index.mjs",
    "extract-openapi": "bun ./scripts/extract-openapi.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@cobalt-web/auth": "workspace:*",
    "@cobalt-web/clients": "workspace:*",
    "@cobalt-web/db": "workspace:*",
    "@cobalt-web/env": "workspace:*",
    "@cobalt-web/server-data": "workspace:*",
    "@cobalt-web/zero": "workspace:*",
    "@hono/zod-openapi": "^1.2.2",
    "@rocicorp/zero": "catalog:",
    "@scalar/hono-api-reference": "^0.10.4",
    "better-auth": "catalog:",
    "dotenv": "catalog:",
    "drizzle-orm": "1.0.0-beta.18-7eb39f0",
    "hono": "^4.8.2",
    "pg": "^8.16.3",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@cobalt-web/config": "workspace:*",
    "@types/bun": "catalog:",
    "@types/pg": "^8.16.0",
    "tsdown": "^0.16.5",
    "typescript": "^5",
    "vitest": "^3.2.0"
  }
}
