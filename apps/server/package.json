{
  "name": "server",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "dev": "bun run --hot src/index.ts",
    "start": "bun run dist/index.mjs"
  },
  "dependencies": {
    "@cobalt-web/auth": "workspace:*",
    "@cobalt-web/db": "workspace:*",
    "@cobalt-web/env": "workspace:*",
    "@cobalt-web/zero": "workspace:*",
    "@rocicorp/zero": "catalog:",
    "better-auth": "catalog:",
    "dotenv": "catalog:",
    "hono": "^4.8.2",
    "pg": "^8.16.3",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@cobalt-web/config": "workspace:*",
    "@types/bun": "catalog:",
    "@types/pg": "^8.16.0",
    "tsdown": "^0.16.5",
    "typescript": "^5"
  }
}
