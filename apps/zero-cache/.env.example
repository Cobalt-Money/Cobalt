# Copy to `.env` in this folder (`cp .env.example .env`) and fill in.
# `bun dev` runs: dotenv -e .env -- zero-cache-dev
#
# ZERO_UPSTREAM_DB should match your authoritative Postgres (same URL as
# DATABASE_URL in apps/server/.env is fine). Use a direct connection, not
# PgBouncer, for replication per Zero docs.
#
# PlanetScale often adds `sslrootcert=system` to the URL. If zero-cache fails
# with "unrecognized configuration parameter sslrootcert", remove that query
# param and keep e.g. `sslmode=verify-full` or `sslmode=require` only.

ZERO_UPSTREAM_DB=postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=verify-full

# Point zero-cache at your Hono Zero routes (API must be up).
ZERO_QUERY_URL=http://localhost:3000/api/zero/query
ZERO_MUTATE_URL=http://localhost:3000/api/zero/mutate

# Optional — default 4848
# ZERO_PORT=4848
