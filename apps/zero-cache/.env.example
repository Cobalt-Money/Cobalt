# Copy to `.env` in this folder (`cp .env.example .env`) and fill in.
# Local dev: `bun run dev` → dotenv + zero-cache-dev
# Docker (rocicorp/zero): `docker compose up` in this folder (see docker-compose.yml)
#
# Upstream DB for replication — use your provider’s default / Zero role URL.
# apps/server/.env uses DATABASE_URL with a separate application role; URLs may
# differ by user even for the same database. Use a direct connection, not
# PgBouncer, for replication per Zero docs.
#
# PlanetScale often adds `sslrootcert=system` to the URL. If zero-cache fails
# with "unrecognized configuration parameter sslrootcert", remove that query
# param and keep e.g. `sslmode=verify-full` or `sslmode=require` only.

ZERO_UPSTREAM_DB=postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=verify-full

# CVR and change DB (single-node: same cluster as upstream is typical).
# https://zero.rocicorp.dev/docs/deployment — production pooler notes apply here.
ZERO_CVR_DB=postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=verify-full
ZERO_CHANGE_DB=postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=verify-full

# Point zero-cache at your Hono Zero routes (API must be up).
# Paths: apps/server/src/routes/zero.ts → POST /api/zero/query and /api/zero/mutate
ZERO_QUERY_URL=http://localhost:3000/api/zero/query
ZERO_MUTATE_URL=http://localhost:3000/api/zero/mutate

# When zero-cache runs in Docker and the API on your machine, use host.docker.internal
# instead of localhost (macOS/Windows Docker Desktop). In production use your real API URL.
# ZERO_QUERY_URL=http://host.docker.internal:3000/api/zero/query
# ZERO_MUTATE_URL=http://host.docker.internal:3000/api/zero/mutate

# Forward cookies from the browser → zero-cache → query/mutate URLs so
# `auth.api.getSession(req)` works (Better Auth cookie). Without this, Zero
# queries run with no user context and return empty data. See:
# https://zero.rocicorp.dev/docs/auth#sending-credentials-cookies
ZERO_QUERY_FORWARD_COOKIES=true
ZERO_MUTATE_FORWARD_COOKIES=true

# --- Docker / production (docker-compose sets NODE_ENV=production + ZERO_REPLICA_FILE) ---
# Uncomment and set when using `docker compose` (required for admin tools in prod):
# ZERO_ADMIN_PASSWORD=your-strong-secret

# Optional — default 4848
# ZERO_PORT=4848
