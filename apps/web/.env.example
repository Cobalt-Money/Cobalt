# Vite client env — validated in packages/env/src/web.ts
# Copy to `.env` in this folder for local dev.

# Required — base URL of the Hono API (Better Auth, Zero query/mutate, etc.)
# Use the same origin as this Vite app (port 3001) so requests hit `/api` on the same origin.
# Vite proxies `/api` to the API server (see vite.config.ts). This keeps OAuth state cookies
# first-party; pointing at a different host/port breaks Google sign-in (state cookie not found).
# Match apps/server `BETTER_AUTH_URL` to this origin (e.g. http://localhost:3001), not :3000.
VITE_SERVER_URL=http://localhost:3001

# Optional — Brandfetch Logo API client id for institution logos (SVG via CDN; https://docs.brandfetch.com/logo-api/overview).
# VITE_BRANDFETCH_CLIENT_ID=

# Optional — Logo.dev publishable key for transaction merchant logos (https://www.logo.dev/dashboard/api-keys).
# VITE_LOGO_DEV_PUBLISHABLE_KEY=

# Optional — Rocicorp zero-cache WebSocket URL. Defaults to http://localhost:4848 in
# src/lib/zero-client.tsx when unset. Set in production to your public zero-cache URL
# (same host as clients use, e.g. https://zero.example.com or wss://…).
# VITE_ZERO_CACHE_URL=http://localhost:4848
